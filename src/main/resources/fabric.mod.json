{
  "schemaVersion": 1,
  "id": "meteor-additions",
  "version": "${version}",
  "name": "MeteorAdditions",
  "description": "Addons for Meteor, partially based off of/inspired by Wurst",
  "authors": ["JFronny"],
  "contact": {
    "email": "projects.contact@frohnmeyer-wds.de",
    "homepage": "https://jfronny.gitlab.io",
    "issues": "https://github.com/JFronny/MeteorAdditions/issues",
    "sources": "https://github.com/JFronny/MeteorAdditions"
  },
  "license": "MIT",
  "icon": "assets/meteor-additions/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
        "dev.jfronny.meteoradditions.MeteorAdditions"
    ],
    "main": [
        "dev.jfronny.meteoradditions.MeteorAdditions::gameInit"
    ],
    "modmenu": [
        "dev.jfronny.meteoradditions.ModMenuCompat"
    ],
    "libjf:config_screen": [
        "dev.jfronny.meteoradditions.ShimUIConfigScreenFactory"
    ]
  },
  "mixins": [
    "MeteorAdditions.mixins.json"
  ],
  "depends": {
    "java": ">=17",
    "fabricloader": ">=0.14.8",
    "fabric-api": "*",
    "minecraft": ">=${mc_version}",
    "meteor-client": "*"
  },
  "custom": {
    "modmenu": {
      "parent": "meteor-client"
    },
    "meteor-client:color": "0,149,0",
    "github:sha": "${gh_hash}"
  }
}
